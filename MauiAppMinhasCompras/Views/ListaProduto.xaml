<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.Views.ListaProduto"
             Title="Minhas Compras">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Somar" Clicked="ToolbarItem_Clicked_1"/>
        <ToolbarItem Text="Adicionar" Clicked="ToolbarItem_Clicked"/>
    </ContentPage.ToolbarItems>

    <ContentPage.Resources>
        <ResourceDictionary>
            <Style TargetType="Label">
                <Setter Property="VerticalTextAlignment" Value="Center"/>
               
            </Style>
            <Style x:Key="cabecalho_listview" TargetType="Grid">
                <Setter Property="Background"
                        Value="{AppThemeBinding Light={StaticResource Gray100},Dark={StaticResource Primary}}"/>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>
    
    <StackLayout>
        <SearchBar x:Name="txt_search" 
                   Margin="15, 0, 0, 0"
                   Placeholder="Busca de Produtos"
                   TextChanged="txt_search_TextChanged"/>
        <Frame
            Padding="10" Margin="10, 0, 10, 10" BackgroundColor="{StaticResource Gray100}">
            <HorizontalStackLayout Spacing="20" VerticalOptions="Center">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Filtrar Categoria: " FontSize="Caption"/>
                    <Picker x:Name="pck_filtro"
                            Title="Selecione"
                            WidthRequest="200"
                            SelectedIndexChanged="pck_filtro_SelectedIndexChanged">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>Todos</x:String>
                                <x:String>Alimentos</x:String>
                                <x:String>Higiene</x:String>
                                <x:String>Limpeza</x:String>
                                <x:String>Outros</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                    <Label Text="Total da Categoria:" FontSize="Caption" />
                    <Label x:Name="lbl_total_categoria" 
                           Text="R$ 0,00" 
                           FontSize="Large" 
                           FontAttributes="Bold" 
                           TextColor="{StaticResource Primary}"/>
                </VerticalStackLayout>
            </HorizontalStackLayout>
        </Frame>
        <ListView x:Name="lst_produtos"
                  IsPullToRefreshEnabled="True"
                  Refreshing="lst_produtos_Refreshing"
                  ItemSelected="lst_produtos_ItemSelected">
            <ListView.Header>
                <Grid ColumnDefinitions="50, *, 100, 100, 100"
                      BackgroundColor="{StaticResource Gray100}">
                    
                    <Label Grid.Column="0" Text="ID" Padding="5" FontAttributes="Bold"/>
                    <Label Grid.Column="1" Text="Descrição" FontAttributes="Bold"/>
                    <Label Grid.Column="2" Text="Preço" FontAttributes="Bold"/>
                    <Label Grid.Column="3" Text="Quantidade" FontAttributes="Bold" />
                    <Label Grid.Column="4" Text="Total" FontAttributes="Bold" />
                </Grid>

            </ListView.Header>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <ViewCell.ContextActions>
                            <MenuItem Text="Remover" Clicked="MenuItem_Clicked" />
                        </ViewCell.ContextActions>
                        <Grid ColumnDefinitions="50, *, 100, 100, 100">
                            
                            <Label Grid.Column="0" Text="{Binding Id}" VerticalTextAlignment="Center"/>
                            <Label Grid.Column="1" Text="{Binding Descricao}" VerticalTextAlignment="Center"/>
                            <Label Grid.Column="2" Text="{Binding Preco, StringFormat='{}{0:C2}'}" VerticalTextAlignment="Center"/>
                            <Label Grid.Column="3" Text="{Binding Quantidade}" VerticalTextAlignment="Center" />
                            <Label Grid.Column="4" Text="{Binding Total, StringFormat='{}{0:C2}'}" VerticalTextAlignment="Center" />
                        </Grid>
                    </ViewCell>
                </DataTemplate>
                
            </ListView.ItemTemplate>
        </ListView>
    </StackLayout>
</ContentPage>